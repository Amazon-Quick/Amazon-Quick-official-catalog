{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Amazon Quick Official Catalog",
  "description": "Schema for the Amazon Quick Official Catalog used to list skills and assets.",
  "type": "object",
  "required": [
    "categories"
  ],
  "additionalProperties": false,
  "properties": {
    "categories": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/Category"
      }
    }
  },
  "$defs": {
    "Category": {
      "type": "object",
      "required": [
        "name",
        "assets"
      ],
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1,
          "maxLength": 64
        },
        "assets": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/Asset"
          }
        }
      }
    },
    "Asset": {
      "type": "object",
      "required": [
        "path",
        "type"
      ],
      "additionalProperties": false,
      "properties": {
        "path": {
          "type": "string",
          "minLength": 3,
          "maxLength": 128,
          "pattern": "^(skills|plugins|mcps|agents|acps)/[a-z0-9][a-z0-9-]*[a-z0-9]$",
          "description": "Relative path in the format '{type_dir}/{kebab-case-name}'. Must start with a valid asset directory prefix and use lowercase kebab-case for the asset name."
        },
        "type": {
          "type": "string",
          "enum": [
            "skill",
            "plugin",
            "mcp",
            "agent",
            "acp"
          ]
        }
      }
    }
  }
}
