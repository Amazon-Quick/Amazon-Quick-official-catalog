{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Amazon Quick Official Catalog",
  "description": "Schema for the Amazon Quick Official Catalog used to list skills and assets.",
  "type": "object",
  "required": [
    "categories"
  ],
  "additionalProperties": false,
  "properties": {
    "categories": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/Category"
      }
    }
  },
  "$defs": {
    "Category": {
      "type": "object",
      "required": [
        "name",
        "assets"
      ],
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1,
          "maxLength": 64
        },
        "slug": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9-]*[a-z0-9]$",
          "description": "Kebab-case identifier for the category (e.g. 'sales-marketing')."
        },
        "description": {
          "type": "string",
          "maxLength": 256,
          "description": "One-sentence description of what this category covers, shown in the UI."
        },
        "assets": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/Asset"
          }
        }
      }
    },
    "Asset": {
      "type": "object",
      "required": [
        "path",
        "type"
      ],
      "additionalProperties": false,
      "properties": {
        "path": {
          "type": "string",
          "minLength": 3,
          "maxLength": 192,
          "pattern": "^(skills|plugins|mcps|agents|acps)/[a-z0-9][a-z0-9-]*/[a-z0-9][a-z0-9-]*[a-z0-9]$",
          "description": "Relative path in the format '{type_dir}/{category}/{kebab-case-name}'."
        },
        "type": {
          "type": "string",
          "enum": [
            "skill",
            "plugin",
            "mcp",
            "agent",
            "acp"
          ]
        }
      }
    }
  }
}
